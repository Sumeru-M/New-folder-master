{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.11" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "CORS_ORIGINS": "@cors_origins",
    "AUTH_SECRET": "@auth_secret",
    "DATA_CACHE_DIR": "/tmp/data_cache"
  }
}
