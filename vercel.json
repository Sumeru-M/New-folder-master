{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".",
  "framework": "python",
  "functions": {
    "app.py": {
      "runtime": "python3.11",
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "env": {
    "CORS_ORIGINS": "@cors_origins",
    "AUTH_SECRET": "@auth_secret",
    "DATA_CACHE_DIR": "/tmp/data_cache"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
